plugin: amazon.aws.aws_ec2

regions:
  - ${region}

compose:
  ansible_connection: 'community.aws.aws_ssm'
  ansible_host: instance_id
  ansible_aws_ssm_instance_id: instance_id
  ansible_aws_ssm_region: ${region}
  ansible_aws_ssm_bucket_name: ${ansible_ssm_bucket_name}
  ansible_python_interpreter: /usr/bin/python3
  ansible_user: ssm-user

filters:
  tag:type:
    - controller
    - worker
    - bgp
  instance-state-name: running

hostnames:
  - tag:Name

keyed_groups:
  - key: tags.type
    separator: ""

groups:
  container_runners: "'controller' in (groups | default([])) or 'worker' in (groups | default([]))"
  controllers: "'controller' in (groups | default([]))"
  leader: "'controller' in (groups | default([]))"
  workers: "'worker' in (groups | default([]))"
  bgp_routers: "'bgp' in (groups | default([]))"
